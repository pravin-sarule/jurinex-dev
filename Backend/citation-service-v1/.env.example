# ============================================================
# citation-service-v1  —  .env.example
# Copy to .env and fill in your values
# ============================================================

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_API_KEY=sk-ant-...            # alias for ANTHROPIC_API_KEY
CLAUDE_MODEL=claude-sonnet-4-6-20251001

# Serper (Google Search)
SERPER_API_KEY=your-serper-api-key

# Indian Kanoon
INDIAN_KANOON_API_TOKEN=your-ik-token
INDIAN_KANOON_TOKEN=your-ik-token    # alias

# Google (Gemini / ADK grounding — optional)
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash

# Agentic Document Service (case context)
DOCUMENT_SERVICE_URL=http://localhost:8092

# PostgreSQL (same citation_db as citation-service)
CITATION_DB_URL="postgresql://user:pass@host:5432/citation_db"
DB_HOST=localhost
DB_PORT=5432
DB_USER=db_user
DB_PASSWORD=password
DB_NAME=citation_db
PG_POOL_MINCONN=1
PG_POOL_MAXCONN=10

# Server
API_HOST=0.0.0.0
API_PORT=8002
DEBUG=false

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Feature flags
CITATION_USE_ADK=true         # set false to use direct pipeline without ADK
CITATION_MAX_FETCH_DOCS=8     # max docs to fetch full text for
