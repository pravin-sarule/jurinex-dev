SERVICE_NAME=agentic-document-service
ENVIRONMENT=development
VERSION=1.0.0
HOST=0.0.0.0
AGENTIC_DOCUMENT_SERVICE_PORT=8092
LOG_LEVEL=INFO
ENABLE_ADK_RUNTIME=true
ENABLE_LEGACY_PROXY=true

DATABASE_URL=postgresql://user:password@host:5432/Document_DB
# Optional: where public.agent_prompts lives (set when UI saves prompts in Draft_DB).
AGENT_PROMPTS_DATABASE_URL=postgresql://user:password@host:5432/Draft_DB
# Optional HTTP fallback if direct Draft_DB access is blocked.
AGENT_DRAFT_SERVICE_URL=http://localhost:8000

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GCS_BUCKET_NAME=agentic-case-documents
# Service account JSON (base64) — used for GCS and Speech-to-Text REST API
GCS_KEY_BASE64=
# Optional: Google Cloud Speech-to-Text API key (not used when GCS_KEY_BASE64 is set)
CLOUD_SPEECH_TO_TEXT_API_KEY=your-speech-to-text-api-key
# Optional: stricter cap for audio-only uploads (0 = same as document max from chat config)
MAX_AUDIO_FILE_SIZE_MB=0
# Speech-to-Text v2 (Chirp + batch_recognize for gs://) wait budget in seconds (e.g. 28800 ≈ 8h)
SPEECH_TO_TEXT_TIMEOUT_SECONDS=28800
SPEECH_TO_TEXT_LANGUAGE_CODE=en-IN
SPEECH_TO_TEXT_ALTERNATIVE_LANGUAGE_CODE=hi-IN
# Use Speech-to-Text v2 (recommended). Set false to force legacy v1 only.
SPEECH_USE_V2=true
# v2 model id (e.g. chirp_2, chirp_3 — see GCP Speech-to-Text v2 model table)
SPEECH_V2_MODEL=chirp_2
# Region for the implicit recognizer (Chirp is not available at "global")
SPEECH_RECOGNIZER_LOCATION=us-central1
# Named recognizer created in GCP Console / gcloud for Chirp 2.
# Create: gcloud alpha speech recognizers create chirp-transcriber \
#           --location=us-central1 --model=chirp_2 --project=YOUR_PROJECT
# Full path used: projects/{project}/locations/us-central1/recognizers/chirp-transcriber
# Set to "" to skip the named recognizer and use the implicit wildcard "_" instead.
SPEECH_V2_RECOGNIZER_ID=chirp-transcriber
# Max concurrent STT API submissions (prevents hitting GCP rate limits).
STT_MAX_CONCURRENT=3
FIRESTORE_DATABASE=(default)
DATASTORE_NAMESPACE=agentic-document-service
BIGQUERY_DATASET=agentic_document_service
VECTOR_STORE_BACKEND=memory
VECTOR_SEARCH_INDEX=
ADK_MODEL=gemini-2.5-pro
EMBEDDING_MODEL=gemini-embedding-001
RETRIEVAL_TOP_K=8
CHUNK_SIZE=750
CHUNK_OVERLAP=160
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=1000
MAX_PARALLEL_DOCUMENT_WORKERS=4
AUTO_FILL_CONFIDENCE_THRESHOLD=0.90
LEGACY_DOCUMENT_SERVICE_URL=http://localhost:8080
PROXY_TIMEOUT_SECONDS=300
