PORT=8010
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Claude AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model — claude-sonnet-4-5 gives the best legal drafting quality
CLAUDE_MODEL=claude-sonnet-4-5

# ── File upload limits ───────────────────────────────────────────────────────
CHAT_DRAFT_MAX_FILES=20
CHAT_DRAFT_MAX_FILE_SIZE_MB=30

# ── Document chunking (for RAG) ──────────────────────────────────────────────
# Larger chunks preserve more legal context per piece
CHAT_DRAFT_CHUNK_SIZE=2400
CHAT_DRAFT_CHUNK_OVERLAP=300

# Top-K chunks for keyword retrieval (used for refinement queries only)
CHAT_DRAFT_TOP_K=30

# Max total characters of document context sent to Claude per generation call
# 180000 chars ≈ 45000 tokens — fits easily in Claude's 200K context window
CHAT_DRAFT_MAX_CONTEXT_CHARS=180000
