# Citation Pipeline V2 is active by default in code; set explicitly in production.
CITATION_PIPELINE_VERSION=v2
CITATION_V2_MAX_IK_SEARCH_CALLS=10
CITATION_V2_MAX_IK_FRAGMENT_CALLS=20
CITATION_V2_MAX_IK_META_CALLS=20
CITATION_V2_MAX_IK_FULL_DOC_CALLS=7
CITATION_V2_MAX_AI_CALLS=1
CITATION_V2_MAX_COST_INR=25
CITATION_V2_MAX_RUNTIME_SECONDS=180
CITATION_V2_MAX_RAW_CANDIDATES=80
CITATION_V2_ENABLE_FINAL_AI_JUDGE=true
CITATION_V2_GEMINI_MODEL=gemini-2.0-flash

# Provider prices used for estimated and stored costs.
CITATION_PRICING_IK_SEARCH_INR=0.50
CITATION_PRICING_IK_DOCUMENT_INR=0.20
CITATION_PRICING_IK_FRAGMENT_INR=0.05
CITATION_PRICING_IK_META_INR=0.02
