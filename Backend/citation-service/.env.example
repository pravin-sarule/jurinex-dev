# Citation Service — copy to .env and fill in values

# Indian Kanoon API (search + document fetch)
INDIAN_KANOON_API_TOKEN=your_ik_token

# Claude API (proxy + keyword extraction from case context)
CLAUDE_API_KEY=your_anthropic_key

# Gemini (citation agent, Clerk, ReportBuilder, and Google Search grounding)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# Qdrant query embeddings (defaults to gemini-embedding-001; set to match indexed chunk model/dims)
GEMINI_QUERY_EMBEDDING_MODEL=models/gemini-embedding-001
# When Elasticsearch is unreachable, Qdrant search uses this cosine similarity floor (set blank to disable)
CITATION_QDRANT_SCORE_THRESHOLD_WHEN_ES_DOWN=0.70
# Keep this aligned with Qdrant vector size:
CITATION_EMBED_OUTPUT_DIMS=768
# Optional embedding tuning:
# CITATION_EMBED_TASK_TYPE=RETRIEVAL_DOCUMENT
# CITATION_EMBED_BATCH_SIZE=16
# CITATION_EMBED_WORKERS=4

# Google Search: uses Gemini Grounding by default. Set to use Serper instead:
# WATCHDOG_GOOGLE_SEARCH_PROVIDER=google_grounding  (default)
# WATCHDOG_GOOGLE_SEARCH_PROVIDER=serper
# WATCHDOG_USE_CLAUDE_SEARCH=true  → use Serper (e.g. when Watchdog uses Claude)

# Serper (fallback when WATCHDOG_GOOGLE_SEARCH_PROVIDER=serper or WATCHDOG_USE_CLAUDE_SEARCH=true)
SERPER_API_KEY=your_serper_key

# PostgreSQL (metadata + reports)
CITATION_DB_URL=postgresql://user:password@host:5432/citation_db
# or DATABASE_URL=postgresql://user:password@host:5432/postgres

# Elasticsearch (full-text search) — local or GCP VM (use public IP or internal IP + port 9200)
# Example GCP VM with TLS + basic auth (docker / tarball install):
#   ELASTICSEARCH_URL=https://YOUR_VM_EXTERNAL_IP:9200
#   ELASTICSEARCH_USERNAME=elastic
#   ELASTICSEARCH_PASSWORD=your_bootstrap_password
# Self-signed HTTPS on the VM (common) — disable strict TLS for the Python client:
#   ELASTIC_VERIFY_CERTS=false
#   ELASTIC_SSL_ASSERT_HOSTNAME=false
#   ELASTIC_SSL_SHOW_WARN=false
# Slow networks: ELASTIC_REQUEST_TIMEOUT=30
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=...
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=
# Also accepted: ELASTIC_PASSWORD, ES_PASSWORD, ELASTIC_USER, ELASTIC_USERNAME

# Qdrant (vector database)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...

# Neo4j (citation graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_password

# Agentic document service (for fetching case file context when generating reports)
# Preferred: AGENTIC_DOCUMENT_SERVICE_URL (host only or /api/files). Backward compatible with DOCUMENT_SERVICE_URL.
AGENTIC_DOCUMENT_SERVICE_URL=http://localhost:8092
# DOCUMENT_SERVICE_URL=http://localhost:5000/docs
GATEWAY_URL=http://localhost:5000

# Auth service (firm-member lookup, usage row display names via /internal/users/bulk)
AUTH_SERVICE_URL=http://localhost:5000/auth/api/auth
# Optional: Bearer token if your auth service protects internal routes
# AUTH_SERVICE_INTERNAL_TOKEN=
# AUTH_SERVICE_TIMEOUT_SECONDS=3

# Optional
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5000

# ── Citation usage cost (INR) — primary; stored as cost_inr in citation_service_usage ──
# FX only used to fill cost_usd column (reference) and to interpret legacy USD env vars below.
CITATION_INR_PER_USD=85

# Indian Kanoon — INR per API call (optional; defaults match api.indiankanoon.org pricing)
# CITATION_PRICING_IK_SEARCH_INR=0.50
# CITATION_PRICING_IK_DOCUMENT_INR=0.20
# CITATION_PRICING_IK_FRAGMENT_INR=0.05
# CITATION_PRICING_IK_META_INR=0.02
# CITATION_PRICING_IK_ORIG_DOC_INR=0.50

# Gemini — INR per 1M input/output tokens; INR per Google Grounding call
# CITATION_PRICING_GEMINI_INPUT_PER_1M_INR=8.5
# CITATION_PRICING_GEMINI_OUTPUT_PER_1M_INR=34
# CITATION_PRICING_GEMINI_GROUNDING_PER_CALL_INR=2.975

# Claude — INR per 1M input/output tokens
# CITATION_PRICING_CLAUDE_INPUT_PER_1M_INR=255
# CITATION_PRICING_CLAUDE_OUTPUT_PER_1M_INR=1275

# Serper — INR per search
# CITATION_PRICING_SERPER_PER_SEARCH_INR=0.85

# Document AI — INR per 1000 pages (OCR / layout when used)
# CITATION_PRICING_DOCUMENT_AI_PER_1000_PAGES_INR=127.5

# Legacy: if you still use USD-only names, they are converted with CITATION_INR_PER_USD:
# CITATION_PRICING_GEMINI_INPUT_PER_1M=0.10
