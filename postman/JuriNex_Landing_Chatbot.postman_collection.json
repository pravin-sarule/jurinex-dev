                  "const slots = pm.response.json();",
                  "if (Array.isArray(slots) && slots[0]?.id) {",
                  "  pm.collectionVariables.set('slot_id', String(slots[0].id));",
                  "  if (pm.environment) pm.environment.set('slot_id', String(slots[0].id));",
                  "}"
